{
  "name": "better-peakbagger",
  "version": "2.2.0",
  "description": "Captures Garmin and Strava into Peakbagger drafts, plus 3D maps, GPX analysis, beta filters, dark mode, and more.",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "wilmtang",
  "homepage": "https://github.com/wilmtang/better-peakbagger",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilmtang/better-peakbagger.git"
  },
  "scripts": {
    "lint": "web-ext lint",
    "build": "web-ext build --overwrite-dest",
    "build:firefox": "node scripts/build-firefox-package.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:metadata:firefox": "node scripts/create-amo-metadata.mjs web-ext-artifacts/amo-metadata.json",
    "release:sign:firefox": "web-ext sign --source-dir=web-ext-artifacts/firefox-source --channel=listed --amo-metadata=web-ext-artifacts/amo-metadata.json --approval-timeout=0 --timeout=600000 --no-input",
    "release:verify-archive": "node scripts/verify-release-archive.mjs",
    "showcase:render": "node scripts/render-showcase.mjs",
    "terrain:verify": "node scripts/verify-terrain-visual.mjs",
    "start:firefox": "node scripts/run-firefox.mjs",
    "start:chromium": "web-ext run --source-dir . --target chromium",
    "test": "node --test \"test/**/*.test.mjs\"",
    "verify:extension": "node scripts/verify-extension.mjs"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "playwright": "^1.61.1",
    "web-ext": "^10.4.0"
  },
  "webExt": {
    "sourceDir": ".",
    "artifactsDir": "web-ext-artifacts",
    "ignoreFiles": [
      "AGENTS.md",
      "CHANGELOG.md",
      "CLAUDE.md",
      "docs",
      "docs/**",
      "package.json",
      "package-lock.json",
      "ROADMAP.md",
      "scripts",
      "scripts/**",
      "store-assets",
      "store-assets/**",
      "test",
      "test/**",
      "tmp",
      "tmp/**"
    ]
  }
}
