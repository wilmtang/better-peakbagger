{
  "name": "better-peakbagger",
  "version": "2.2.0",
  "description": "Captures Garmin and Strava into Peakbagger drafts, plus 3D maps, GPX analysis, beta filters, dark mode, and more.",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "wilmtang",
  "homepage": "https://github.com/wilmtang/better-peakbagger",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilmtang/better-peakbagger.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:release": "node scripts/build.mjs --minify",
    "watch": "node scripts/build.mjs --watch",
    "lint": "npm run build && web-ext lint --source-dir dist",
    "package": "npm run build:release && web-ext build --source-dir dist --overwrite-dest",
    "build:firefox": "node scripts/build-firefox-package.mjs",
    "release:bump": "node scripts/release-bump.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:metadata:firefox": "node scripts/create-amo-metadata.mjs web-ext-artifacts/amo-metadata.json",
    "release:sign:firefox": "web-ext sign --source-dir=web-ext-artifacts/firefox-source --channel=listed --amo-metadata=web-ext-artifacts/amo-metadata.json --approval-timeout=0 --timeout=600000 --no-input",
    "release:verify-archive": "node scripts/verify-release-archive.mjs",
    "pretest": "npm run build",
    "showcase:render": "npm run build && node scripts/render-showcase.mjs",
    "terrain:verify": "npm run build && node scripts/verify-terrain-visual.mjs",
    "start:firefox": "node scripts/run-development.mjs firefox",
    "start:chromium": "node scripts/run-development.mjs chromium",
    "test": "node --test \"test/**/*.test.mjs\"",
    "verify:extension": "npm run build && node scripts/verify-extension.mjs"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-highlight": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-subscript": "^3.28.0",
    "@tiptap/extension-superscript": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-text-style": "^3.28.0",
    "@tiptap/extensions": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "chart.js": "^4.5.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.24.0",
    "marked": "^18.0.6",
    "playwright": "^1.61.1",
    "tz-lookup": "^6.1.25",
    "web-ext": "^10.4.0"
  },
  "webExt": {
    "sourceDir": ".",
    "artifactsDir": "web-ext-artifacts",
    "ignoreFiles": [
      "AGENTS.md",
      "CHANGELOG.md",
      "CLAUDE.md",
      "docs",
      "docs/**",
      "package.json",
      "package-lock.json",
      "ROADMAP.md",
      "scripts",
      "scripts/**",
      "store-assets",
      "store-assets/**",
      "test",
      "test/**",
      "tmp",
      "tmp/**"
    ]
  }
}
