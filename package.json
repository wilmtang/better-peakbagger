{
  "name": "better-peakbagger",
  "version": "1.4.0",
  "description": "Captures your Garmin and Strava activities into confidence-ranked Peakbagger drafts, plus GPX analysis, beta filters, and dark mode.",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "wilmtang",
  "homepage": "https://github.com/wilmtang/better-peakbagger",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilmtang/better-peakbagger.git"
  },
  "scripts": {
    "lint": "web-ext lint",
    "build": "web-ext build --overwrite-dest",
    "build:chrome": "node scripts/build-chrome-package.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:metadata:firefox": "node scripts/create-amo-metadata.mjs web-ext-artifacts/amo-metadata.json",
    "release:sign:firefox": "web-ext sign --channel=listed --amo-metadata=web-ext-artifacts/amo-metadata.json --approval-timeout=0 --timeout=600000 --no-input",
    "release:verify-archive": "node scripts/verify-release-archive.mjs",
    "showcase:render": "node scripts/render-showcase.mjs",
    "start:firefox": "web-ext run --source-dir .",
    "start:chromium": "web-ext run --source-dir . --target chromium",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "jsdom": "^29.1.1",
    "web-ext": "^10.4.0"
  },
  "webExt": {
    "sourceDir": ".",
    "artifactsDir": "web-ext-artifacts",
    "ignoreFiles": [
      "AGENTS.md",
      "CHANGELOG.md",
      "docs",
      "docs/**",
      "package.json",
      "package-lock.json",
      "ROADMAP.md",
      "scripts",
      "scripts/**",
      "store-assets",
      "store-assets/**",
      "test",
      "test/**",
      "tmp",
      "tmp/**"
    ]
  }
}
