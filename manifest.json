{
  "manifest_version": 3,
  "name": "Better Peakbagger",
  "version": "2.2.0",
  "description": "Captures Garmin and Strava into Peakbagger drafts, plus 3D maps, GPX analysis, beta filters, dark mode, and more.",
  "homepage_url": "https://github.com/wilmtang/better-peakbagger",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabGroups",
    "alarms"
  ],
  "host_permissions": [
    "https://peakbagger.com/*",
    "https://www.peakbagger.com/*"
  ],
  "optional_host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_title": "Capture activity for Peakbagger",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.peakbagger.com/climber/ascentedit.aspx*",
        "*://www.peakbagger.com/climber/AscentEdit.aspx*",
        "*://peakbagger.com/climber/ascentedit.aspx*",
        "*://peakbagger.com/climber/AscentEdit.aspx*"
      ],
      "css": [
        "css/report-editor.css"
      ],
      "js": [
        "vendor/marked.umd.js",
        "content/ascent-editor.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.peakbagger.com/*"
      ],
      "js": [
        "content/theme.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/climber/ascent.aspx*",
        "*://www.peakbagger.com/climber/Ascent.aspx*",
        "*://peakbagger.com/climber/ascent.aspx*",
        "*://peakbagger.com/climber/Ascent.aspx*"
      ],
      "js": [
        "content/ascent-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/climber/ascent.aspx*",
        "*://www.peakbagger.com/climber/Ascent.aspx*",
        "*://peakbagger.com/climber/ascent.aspx*",
        "*://peakbagger.com/climber/Ascent.aspx*"
      ],
      "css": [
        "css/ascent-backup.css"
      ],
      "js": [
        "content/ascent-backup.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/climber/ascent.aspx*",
        "*://www.peakbagger.com/climber/Ascent.aspx*",
        "*://peakbagger.com/climber/ascent.aspx*",
        "*://peakbagger.com/climber/Ascent.aspx*"
      ],
      "js": [
        "vendor/chart.umd.min.js",
        "vendor/tz-lookup.js",
        "content/gpx-analyzer.js"
      ],
      "run_at": "document_end",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://www.peakbagger.com/climber/ascent.aspx*",
        "*://www.peakbagger.com/climber/Ascent.aspx*",
        "*://peakbagger.com/climber/ascent.aspx*",
        "*://peakbagger.com/climber/Ascent.aspx*"
      ],
      "css": [
        "css/terrain-map.css"
      ],
      "js": [
        "content/terrain-map.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/climber/PeakAscents.aspx*",
        "*://www.peakbagger.com/climber/peakascents.aspx*",
        "*://www.peakbagger.com/climber/ClimbListC.aspx*",
        "*://www.peakbagger.com/climber/climblistc.aspx*",
        "*://peakbagger.com/climber/PeakAscents.aspx*",
        "*://peakbagger.com/climber/peakascents.aspx*",
        "*://peakbagger.com/climber/ClimbListC.aspx*",
        "*://peakbagger.com/climber/climblistc.aspx*"
      ],
      "js": [
        "content/ascent-filter.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/Peak.aspx*",
        "*://www.peakbagger.com/peak.aspx*",
        "*://peakbagger.com/Peak.aspx*",
        "*://peakbagger.com/peak.aspx*"
      ],
      "js": [
        "content/peak-map-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/Peak.aspx*",
        "*://www.peakbagger.com/peak.aspx*",
        "*://peakbagger.com/Peak.aspx*",
        "*://peakbagger.com/peak.aspx*"
      ],
      "css": [
        "css/peak-links.css"
      ],
      "js": [
        "content/peak-links.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "*://www.peakbagger.com/Peak.aspx*",
        "*://www.peakbagger.com/peak.aspx*",
        "*://peakbagger.com/Peak.aspx*",
        "*://peakbagger.com/peak.aspx*"
      ],
      "js": [
        "content/peak-map.js"
      ],
      "run_at": "document_end",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://www.peakbagger.com/Peak.aspx*",
        "*://www.peakbagger.com/peak.aspx*",
        "*://peakbagger.com/Peak.aspx*",
        "*://peakbagger.com/peak.aspx*"
      ],
      "css": [
        "css/terrain-map.css"
      ],
      "js": [
        "content/terrain-map.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.peakbagger.com/*BigMap.aspx*",
        "*://*.peakbagger.com/*bigmap.aspx*"
      ],
      "js": [
        "content/big-map-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.peakbagger.com/*BigMap.aspx*",
        "*://*.peakbagger.com/*bigmap.aspx*"
      ],
      "js": [
        "content/big-map.js"
      ],
      "run_at": "document_end",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.peakbagger.com/*BigMap.aspx*",
        "*://*.peakbagger.com/*bigmap.aspx*"
      ],
      "css": [
        "css/terrain-map.css"
      ],
      "js": [
        "content/terrain-map.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "terrain/terrain.html"
      ],
      "matches": [
        "*://*.peakbagger.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "better-peakbagger@wilmtang.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "locationInfo"
        ]
      }
    }
  }
}
